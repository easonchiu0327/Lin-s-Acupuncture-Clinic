# Google Maps API Key for displaying live reviews
# Get your API key from: https://console.cloud.google.com
# Enable: Places API and Maps JavaScript API
LIN_CLINIC_GOOGLE_MAPS_KEY=your_api_key_here

# Gmail Configuration for Contact Form
# For Gmail, use an App Password (not your regular password)
# Steps: 1. Enable 2-Step Verification on Gmail account
#        2. Go to myaccount.google.com/apppasswords
#        3. Select "Mail" and "Windows Computer"
#        4. Copy the generated 16-character password below
CLINIC_EMAIL=lin5002223@gmail.com
CLINIC_EMAIL_PASSWORD=your_16_char_app_password_here

