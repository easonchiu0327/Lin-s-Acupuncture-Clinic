{
  "version": 2,
  "builds": [
    {
      "src": "api/serve.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "owners-picture.jpg"
        ]
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "api/serve.js"
    }
  ]
}
