{
  "version": 2,
  "builds": [
    {
      "src": "api/serve.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/serve.js"
    },
    {
      "src": "./(.*)",
      "dest": "api/serve.js"
    }
  ]
}
